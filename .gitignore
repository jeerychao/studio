# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js

# Next.js build outputs
/.next/
/out/

# Production
/build

# Miniflare
.mf

# Dotenv files
*.env
*.env.local
*.env.development.local
*.env.test.local
# *.env.production.local # Keep this commented if you intend to copy it in Dockerfile for some setups
# Keep production.env for docker-compose out of git, if it contains secrets
production.env 

# System Files
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# IDE files
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# Typescript files
*.tsbuildinfo
# tsconfig.tsbuildinfo # Typically not ignored if it's part of the build process config

# SQLite
# If you want to commit the pre-seeded database, DO NOT ignore ipam.db
# /prisma/ipam.db
/prisma/*-journal # Ignore journal files for SQLite

# Prisma
/prisma/migrations/*.sqlite # Example if migrations create temp dbs, usually not needed for SQLite main db file

# Temp files
*.tmp
*.bak
*~
