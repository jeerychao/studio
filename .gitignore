
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Next.js local build artifacts
.next

# Environment variables
# Ignore all .env files by default
.env*
# But specifically un-ignore .env.example and production.env if they are meant to be templates
!.env.example
!production.env

# Prisma
# Ignore the SQLite database file used for development
prisma/dev.db
# Ignore schema diff files if any are generated locally and not intended for commit
prisma/migrations/*/.sql
# Ignore .env file within prisma directory if it exists
prisma/.env

# Local User Uploads (if any)
# Example: /public/uploads/

# IDE specific
.vscode/
.idea/
*.project
*.tmproj
*.sublime-workspace

# Docker
docker-compose.override.yml
docker-compose.local.yml
# If Docker volumes are mapped to local folders for persistence (outside of named volumes)
# and those folders contain transient data, consider ignoring them.
# Example: ./data/ (if you map a local ./data to a volume)

# Logs folder, often generated by applications
/logs
*.log
# But don't ignore .gitkeep if you want to keep the directory structure
!logs/.gitkeep

# TypeScript build output (if not using Next.js's build exclusively)
/dist
*.tsbuildinfo
