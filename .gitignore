# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build

# Prisma
# SQLite database file - should not be versioned if it's dynamically generated/seeded
# or if it contains sensitive/large data.
# If your dev.db is small and only contains mock/seed data and you WANT to share it for dev setup,
# you might consider versioning it, but it's generally not recommended for .db files.
prisma/dev.db
# You might also want to ignore .db-journal files if they appear
prisma/dev.db-journal

# dotenv environment variables file
.env
.env*.local
# Environment file for production docker, might contain secrets
production.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.logs/

# Misc
.DS_Store
*.pem
*.tsbuildinfo
*.idea
