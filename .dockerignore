
# Git files
.git
.gitignore

# Node modules
node_modules

# Next.js build output (we build it inside Docker)
.next

# Development and debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# VSCode specific
.vscode

# Firebase App Hosting config (not needed for generic Docker)
apphosting.yaml

# README and components.json (usually not needed in prod image)
README.md
components.json

# Environment files (should be passed at runtime or build time)
.env
.env*.local
.env.development
.env.production

# Local test files or documentation
# docs
# tests
