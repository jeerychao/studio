# .dockerignore
# Prevents unnecessary files and folders from being copied into the Docker image,
# speeding up the build process and reducing image size.

# Git files
.git
.gitignore

# Node modules (will be installed within Docker)
node_modules

# Next.js cache and build outputs (will be generated within Docker)
.next

# IDE and OS-specific files
.vscode
*.env
*.env.local
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker files (if they are in the context but not needed inside the image itself)
Dockerfile
docker-compose.yml
production.env
README.md
# Add any other files or directories that are not needed for the runtime application
.logs
