
# Prisma (and Next.js) will automatically load variables from this file in development.
# See https://www.prisma.io/docs/guides/development-environments/environment-variables/managing-the-database-connection-url
# and https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables

# Example DATABASE_URL for a local SQLite database. Prisma uses this for CLI commands.
# Next.js might need it at runtime if not configured elsewhere.
DATABASE_URL="file:./dev.db"

# IMPORTANT: Replace with a securely generated 32-byte (64-character hex) key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="000102030405060708090a0b0c0d0e0f000102030405060708090a0b0c0d0e0f"

# NEXT_PUBLIC_BASE_URL might be needed if your app relies on it during build or server-side rendering by Next.js
# For local development, if your app runs on port 3000:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# If using NextAuth, ensure this is set, aligning with NEXT_PUBLIC_BASE_URL
# NEXTAUTH_URL=${NEXT_PUBLIC_BASE_URL}
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEXTAUTH_SECRET=your_nextauth_secret_here
