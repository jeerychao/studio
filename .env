DATABASE_URL="file:./prisma/dev.db"
# IMPORTANT: Replace the value below with your actual 64-character hexadecimal ENCRYPTION_KEY.
# This key MUST be the same one used when your database was last seeded (e.g., the one starting with 9695b...).
# Generate a new secure key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# if you are setting up for the first time or if you re-seed after changing this.
ENCRYPTION_KEY="YOUR_64_CHARACTER_HEX_ENCRYPTION_KEY_STARTING_WITH_9695b"
