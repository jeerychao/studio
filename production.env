NODE_ENV=production
HOST=0.0.0.0
HOSTNAME=0.0.0.0
PORT=3000
DATABASE_URL=file:/app/prisma/dev.db
# 如果您使用NextAuth，请取消注释并设置这些：
# NEXTAUTH_URL=http://17.100.100.253:3010 
# NEXTAUTH_SECRET= # 请生成一个强密钥并在此处设置

# 可选的公共 URL（如果您的应用需要知道其外部可访问的 URL）
# NEXT_PUBLIC_BASE_URL=http://17.100.100.253:3010
# NEXT_PUBLIC_VERCEL_URL=17.100.100.253:3010 # 如果您不使用Vercel，可以移除此行或设置为空

NODE_OPTIONS=--max-old-space-size=4096
# DEBUG=prisma:*,next:* # 调试时可以取消注释，生产中建议注释掉