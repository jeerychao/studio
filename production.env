
# This file is used by docker-compose.yml to set environment variables for the container.
# For a true production deployment (e.g., not using docker-compose, or deploying the image directly),
# these variables should be set directly in the runtime environment of your hosting platform/server.

# --- REQUIRED FOR PRODUCTION ---
# Set this to the publicly accessible URL of your application.
# Example: NEXT_PUBLIC_BASE_URL=https://ipam.yourdomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:8081

# --- DATABASE ---
# For SQLite (as used in development and the current Docker setup):
# This points to the SQLite file inside the container.
# If you mount a volume to /app/prisma in docker-compose.yml, this will use the db in the volume.
DATABASE_URL="file:/app/prisma/dev.db"

# For a production PostgreSQL database (example):
# DATABASE_URL="postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name?schema=public"

# For a production MySQL database (example):
# DATABASE_URL="mysql://your_db_user:your_db_password@your_db_host:3306/your_db_name"


# --- NEXTAUTH / AUTHENTICATION (If you integrate NextAuth.js or similar) ---
# NEXTAUTH_URL=${NEXT_PUBLIC_BASE_URL}
# NEXTAUTH_SECRET= # Generate a strong secret: `openssl rand -hex 32`

# --- OTHER APPLICATION SPECIFIC VARIABLES (if any) ---
# EXAMPLE_API_KEY=your_api_key_here
