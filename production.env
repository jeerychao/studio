
# Environment variables for the Docker container in production

# Prisma Database URL
# Points to the SQLite file inside the container, relative to the prisma schema location if Prisma Client is invoked from /app
# Or an absolute path if needed. Given WORKDIR /app and prisma dir at /app/prisma:
DATABASE_URL="file:/app/prisma/dev.db"

# Next.js specific (if any, usually not needed for basic start)
# NEXT_PUBLIC_SOME_VAR=some_value

# Port the Next.js app runs on inside the container (should match EXPOSE in Dockerfile)
PORT=3000
