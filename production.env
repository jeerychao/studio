
# Environment variables for production in Docker

# Prisma Database URL for SQLite within the container
DATABASE_URL="file:/app/prisma/dev.db"

NEXT_PUBLIC_BASE_URL=http://localhost:8081

# Example: Define the base URL for your application if needed
# NEXT_PUBLIC_BASE_URL=http://yourdomain.com
# NEXTAUTH_URL=http://yourdomain.com # If using NextAuth
