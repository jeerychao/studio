
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

model Subnet {
  id             String      @id @default(uuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?     // User-defined name for the subnet
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull) // If VLAN deleted, set vlanId to null
  ipAddresses    IPAddress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id          String    @id @default(uuid())
  vlanNumber  Int       @unique // 1-4094
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVlanToIPAddresses") // IPs directly associated with this VLAN

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id            String        @id @default(uuid())
  ipAddress     String        // e.g., "192.168.1.100"
  subnetId      String?
  subnet        Subnet?       @relation(fields: [subnetId], references: [id], onDelete: Cascade) // If Subnet deleted, IP is deleted
  directVlanId  String?       // For IPs not in a subnet but directly on a VLAN
  directVlan    VLAN?         @relation("DirectVlanToIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull)
  status        String        // e.g., "allocated", "free", "reserved"
  isGateway     Boolean?      @default(false)
  allocatedTo   String?       // e.g., "Server-01", "John Doe PC"
  usageUnit     String?       // e.g., "Marketing Department", "R&D Lab"
  contactPerson String?       // e.g., "Jane Smith"
  phone         String?       // e.g., "123-456-7890"
  description   String?
  lastSeen      DateTime?     @updatedAt // Automatically updated

  deviceConnections DeviceConnection[] @relation("IPAddressToConnections")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // An IP must be unique within its subnet, or globally if no subnet
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String    // In a real app, this would be hashed
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id])
  avatar    String?   // URL or path to avatar image
  lastLogin DateTime?
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  permissions Permission[] @relation("RoleToPermissions")
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String @id // e.g., "subnet.create", "user.delete"
  name        String @unique // e.g., "Create Subnets"
  group       String // e.g., "Subnet Management"
  description String?
  roles       Role[] @relation("RoleToPermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // User who performed the action
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull) // If user deleted, keep log but nullify userId
  username  String   // Denormalized username for easier display even if user is deleted
  action    String   // e.g., "create_subnet", "login_user"
  timestamp DateTime @default(now())
  details   String?  // e.g., "Created subnet 192.168.1.0/24"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ISP (Internet Service Provider)
model Isp { // Changed from ISP to Isp for Prisma convention
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  contactInfo String?   // Contact number, email, etc.
  // Future: Add relation to connections/circuits if needed
  deviceConnections DeviceConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DeviceType {
  ROUTER
  SWITCH
  FIREWALL
  SERVER
  ACCESS_POINT
  OLT // Optical Line Terminal
  DDN_DEVICE // DDN/专线设备
  OTHER
}

// Network Device
model Device {
  id           String      @id @default(uuid())
  name         String      @unique // User-friendly name for the device
  deviceType   DeviceType? // e.g., Router, Switch, Firewall
  location     String?     // Physical location or rack details
  managementIp String?     @unique // Management IP address of the device
  brand        String?
  modelNumber  String?
  serialNumber String?     @unique
  description  String?

  // Connections originating from this device
  localConnections DeviceConnection[] @relation("LocalDeviceToConnections")
  // Connections terminating at this device (placeholder if needed for symmetric relations)
  // remoteConnections DeviceConnection[] @relation("RemoteDeviceToConnections")


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Placeholder for Phase 3 - will be expanded
model DeviceConnection {
  id String @id @default(uuid())

  localDeviceId String
  localDevice Device @relation("LocalDeviceToConnections", fields: [localDeviceId], references: [id])
  
  // remoteDeviceId String? // Optional if connection is to an external entity not in Device model
  // remoteDevice Device? @relation("RemoteDeviceToConnections", fields: [remoteDeviceId], references: [id])

  ipAddressId String? // IP address used on the local device for this connection
  ipAddress IPAddress? @relation("IPAddressToConnections", fields: [ipAddressId], references: [id])

  ispId String? // ISP providing this connection
  isp Isp? @relation(fields: [ispId], references: [id])
  
  // Other fields like port, bandwidth, circuit ID, notes etc. to be added in Phase 3
  connectionType String? // e.g., "Fiber", "Ethernet", "专线"
  bandwidth String? // e.g., "100Mbps", "1Gbps"
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
