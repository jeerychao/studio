
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Subnet {
  id             String      @id
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Restrict)
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([vlanId])
}

model VLAN {
  id             String    @id
  vlanNumber     Int       @unique
  name           String?
  description    String?
  subnets        Subnet[]
  ipAddresses    IPAddress[] @relation("DirectVlanForIP") // Relation for IPs directly associated with a VLAN
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model IPAddress {
  id             String      @id
  ipAddress      String
  subnetId       String?
  subnet         Subnet?     @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  directVlanId   String?     // For IPs directly associated, not via subnet
  directVlan     VLAN?       @relation("DirectVlanForIP", fields: [directVlanId], references: [id], onDelete: Restrict)
  status         String      // "allocated", "free", "reserved"
  isGateway      Boolean?    @default(false)
  allocatedTo    String?
  usageUnit      String?
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime?
  deviceConnections DeviceConnection[] @relation("LocalIpForConnection")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([ipAddress, subnetId]) // Ensures IP is unique within its subnet, or unique globally if subnetId is null
  @@index([subnetId])
  @@index([directVlanId])
}

model User {
  id          String    @id
  username    String    @unique
  email       String    @unique
  password    String
  avatar      String?
  lastLogin   DateTime?
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs   AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([roleId])
}

model Role {
  id          String       @id
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id // e.g., "subnet.create", "user.view"
  name        String   @unique
  group       String   // e.g., "Subnet Management", "User Access"
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id
  userId    String?  // Can be null for system-generated logs
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?  // Denormalized username for easier display, even if user is deleted
  action    String
  timestamp DateTime @default(now())
  details   String?

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

model Isp {
  id           String    @id
  name         String    @unique
  description  String?
  contactInfo  String?
  connections  DeviceConnection[] @relation("IspForConnection")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Device {
  id            String    @id
  name          String    @unique
  deviceType    String?   // e.g., ROUTER, SWITCH, FIREWALL, SERVER, etc. Use an enum in your app logic.
  location      String?
  managementIp  String?   @unique
  brand         String?
  modelNumber   String?
  serialNumber  String?   @unique
  description   String?
  localConnections DeviceConnection[] @relation("LocalDeviceForConnection")
  remoteConnections DeviceConnection[] @relation("RemoteDeviceForConnection")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DeviceConnection {
  id                 String   @id
  localDeviceId      String
  localDevice        Device   @relation("LocalDeviceForConnection", fields: [localDeviceId], references: [id], onDelete: Cascade)
  localIpId          String?
  localIpAddress     IPAddress? @relation("LocalIpForConnection", fields: [localIpId], references: [id], onDelete: SetNull)
  remoteDeviceId     String?
  remoteDevice       Device?  @relation("RemoteDeviceForConnection", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  remoteHostnameOrIp String?
  ispId              String?
  isp                Isp?     @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull)
  connectionType     String   // E.g., ETHERNET_COPPER, ETHERNET_FIBER, WIFI, VPN
  status             String   // E.g., ACTIVE, INACTIVE, MAINTENANCE
  bandwidth          String?  // E.g., "1 Gbps", "100 Mbps"
  localInterface     String?
  remoteInterface    String?
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([localDeviceId])
  @@index([localIpId])
  @@index([remoteDeviceId])
  @@index([ispId])
}
