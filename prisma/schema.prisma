datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  password    String
  avatar      String?
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  lastLogin   DateTime?
  auditLogs   AuditLog[] // Relation to AuditLog model

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Role {
  id          String    @id // Fixed IDs for seed, no @default
  name        String    @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RoleToPermission")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Permission {
  id          String   @id // Fixed IDs for seed, no @default
  name        String   @unique
  group       String
  description String?
  roles       Role[]   @relation("RoleToPermission")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subnet {
  id             String      @id // Fixed IDs for seed, no @default
  cidr           String      @unique // e.g., 192.168.1.0/24
  networkAddress String      // e.g., 192.168.1.0
  subnetMask     String      // e.g., 255.255.255.0
  ipRange        String?     // e.g., 192.168.1.1 - 192.168.1.254
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[] // Relation to IPAddress model
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model VLAN {
  id          String    @id // Fixed IDs for seed, no @default
  vlanNumber  Int       @unique
  name        String?
  description String?
  subnets     Subnet[] // Relation to Subnet model
  ipAddresses IPAddress[] @relation("VLANToIPAddress") // Direct IP association with VLAN
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model IPAddress {
  id            String  @id // Fixed IDs for seed, no @default
  ipAddress     String
  subnetId      String?
  subnet        Subnet? @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  directVlanId  String? // For IPs directly associated with a VLAN, not through subnet
  directVlan    VLAN?   @relation("VLANToIPAddress", fields: [directVlanId], references: [id])

  status        String    // e.g., "allocated", "free", "reserved"
  isGateway     Boolean?  @default(false)
  allocatedTo   String?   // e.g., "Server-01", "John Doe PC"
  usageUnit     String?   // e.g., "IT Department", "Finance"
  contactPerson String?
  phone         String?
  description   String?
  lastSeen      DateTime? @updatedAt // Automatically updated

  // New fields based on user request
  selectedOperatorName   String?
  selectedOperatorDevice String?
  selectedAccessType     String? // e.g., "独享", "共享"
  selectedLocalDeviceName String?
  selectedDevicePort     String?
  selectedPaymentSource  String? // e.g., "自费", "财政付费"

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([ipAddress, subnetId]) // IP must be unique within its subnet, or globally if no subnet
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?   // Can be null for system-generated logs
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull) // If user deleted, log remains but userId is null
  username  String?   // Store username at time of log creation for history
  action    String
  details   String?
  timestamp DateTime  @default(now())
}

// New Dictionary Models
model OperatorDictionary {
  id             String   @id @default(cuid())
  operatorName   String   @unique // 运营商名称
  operatorDevice String?  // 运营商设备
  accessType     String?  // 接入方式 (e.g., "独享", "共享")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LocalDeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique // 本端设备名称
  port       String?  // 端口
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PaymentSourceDictionary {
  id          String   @id @default(cuid())
  sourceName  String   @unique // 费用来源
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
