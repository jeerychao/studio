
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Models for IPAM Lite

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., 192.168.1.0/24
  networkAddress String      // e.g., 192.168.1.0
  subnetMask     String      // e.g., 255.255.255.0
  ipRange        String?     // e.g., 192.168.1.1 - 192.168.1.254
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation("SubnetVLAN", fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[] @relation("IPSubnet")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id                String      @id @default(cuid())
  vlanNumber        Int         @unique // e.g., 10, 20
  description       String?
  subnets           Subnet[]    @relation("SubnetVLAN")
  ipAddressesDirect IPAddress[] @relation("IPAddressVLAN") // Added opposite relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id           String  @id @default(cuid())
  ipAddress    String  // e.g., 192.168.1.100
  status       String  // Changed from IPAddressStatus enum
  allocatedTo  String? // e.g., "John Doe's Laptop", "Server-01"
  description  String?
  lastSeen     DateTime?

  subnetId String?
  subnet   Subnet? @relation("IPSubnet", fields: [subnetId], references: [id], onDelete: SetNull)

  vlanId       String?         // IP-specific VLAN override
  vlan         VLAN?           @relation("IPAddressVLAN", fields: [vlanId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique constraint for IP within a specific subnet, or globally if no subnet
  @@unique([ipAddress, subnetId])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String   // In a real app, this should be hashed
  avatar    String?
  lastLogin DateTime?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  auditLogs AuditLog[] // User can have many audit log entries

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // Changed from RoleName enum
  description String?
  users       User[]       // A role can be assigned to multiple users
  permissions Permission[] // A role can have multiple permissions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String @id @unique // Changed from PermissionId enum
  name        String // e.g., "View Dashboard", "Create Subnets"
  group       String // e.g., "Dashboard", "Subnet Management"
  description String?
  roles       Role[] // A permission can be part of multiple roles

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // Can be null for system actions
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull) // If user is deleted, log remains but userId is nullified
  username  String?  // Denormalized for easier display if user is deleted
  action    String   // e.g., "create_subnet", "login_user"
  details   String?  // e.g., "Created subnet 192.168.1.0/24"
  timestamp DateTime @default(now())
}

// Native enums removed as SQLite connector does not support them.
// String types will be used in Prisma, and validation/constraints
// will be handled at the application/seed level using TypeScript types.
