
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false)
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull) // Changed onDelete to SetNull
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([vlanId])
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVLANOnIP") // For IPs directly associated with a VLAN, not via subnet
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model IPAddress {
  id             String   @id @default(cuid())
  ipAddress      String   // e.g., "192.168.1.100"
  subnetId       String?
  subnet         Subnet?  @relation(fields: [subnetId], references: [id], onDelete: SetNull) // Changed onDelete to SetNull
  directVlanId   String?  // For direct VLAN association
  directVlan     VLAN?    @relation("DirectVLANOnIP", fields: [directVlanId], references: [id], onDelete: SetNull)
  status         String   // e.g., "allocated", "free", "reserved"
  isGateway      Boolean? @default(false)
  allocatedTo    String?  // e.g., device name, user, service
  usageUnit      String?  // e.g., department, project
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime @default(now()) @updatedAt // Assuming lastSeen is essentially updatedAt

  peerUnitName   String? // New: Manual input for peer/customer/partner name
  peerDeviceName String? // New: Name of the device on the peer side (from DeviceDictionary)
  peerPortName   String? // New: Port on the peer device (derived from selected DeviceDictionary entry's port)
  
  selectedAccessType      String? // Name from AccessTypeDictionary
  selectedLocalDeviceName String? // Name from DeviceDictionary
  selectedDevicePort      String? // Port from DeviceDictionary
  selectedPaymentSource   String? // Name from PaymentSourceDictionary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // IP must be unique within a subnet (or globally if subnetId is null)
  @@index([subnetId])
  @@index([directVlanId])
  @@index([status])
  @@index([allocatedTo])
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  password    String
  phone       String?
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  avatar      String?
  auditLogs   AuditLog[]
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([roleId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "subnet.create"
  group       String   // e.g., "Subnet Management"
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // Can be null for system events
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?  // Denormalized for easier display even if user is deleted
  action    String   // e.g., "create_subnet", "user_login"
  timestamp DateTime @default(now())
  details   String?  // JSON string or plain text for more details
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

// Renamed from LocalDeviceDictionary
model DeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique
  port       String?  // Example: "GigabitEthernet1/0/1", "Eth0/0"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PaymentSourceDictionary {
  id         String   @id @default(cuid())
  sourceName String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AccessTypeDictionary {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Renamed from NetworkInterfaceTypeDictionary
model InterfaceTypeDictionary {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "GigabitEthernet", "ge-", "TenGigabitEthernet"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
