
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id          String    @id @default(uuid())
  username    String    @unique
  email       String    @unique
  password    String
  phone       String?
  avatar      String?
  lastLogin   DateTime? @map("last_login")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  roleId      String    @map("role_id")
  role        Role      @relation(fields: [roleId], references: [id])
  auditLogs   AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // Administrator, Operator, Viewer
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., 'subnet.create'
  group       String   // e.g., 'Subnet Management'
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model Subnet {
  id             String      @id @default(uuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      @map("network_address") // e.g., "192.168.1.0"
  subnetMask     String      @map("subnet_mask")     // e.g., "255.255.255.0"
  ipRange        String?     @map("ip_range")        // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false) @map("dhcp_enabled")
  vlanId         String?     @map("vlan_id")
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([vlanId])
  @@map("subnets")
}

model VLAN {
  id          String    @id @default(uuid())
  vlanNumber  Int       @unique @map("vlan_number") // 1-4094
  name        String?
  description String?
  subnets     Subnet[]
  directIPs   IPAddress[] @relation("DirectVLANIPAddresses") // IPs directly associated with this VLAN
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("vlans")
}

model IPAddress {
  id                      String          @id @default(uuid())
  ipAddress               String          @unique @map("ip_address")
  subnetId                String?         @map("subnet_id")
  directVlanId            String?         @map("direct_vlan_id")
  status                  String          // allocated, free, reserved
  isGateway               Boolean?        @default(false) @map("is_gateway")
  allocatedTo             String?         @map("allocated_to")
  usageUnit               String?         @map("usage_unit")
  contactPerson           String?         @map("contact_person")
  phone                   String?
  description             String?
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  // Peer information
  peerUnitName            String?         @map("peer_unit_name")
  peerDeviceName          String?         @map("peer_device_name")
  peerPortName            String?         @map("peer_port_name")

  // Local device and port information for this IP (if applicable)
  selectedLocalDeviceName String?         @map("selected_local_device_name")
  selectedDevicePort      String?         @map("selected_device_port")

  // Additional context from dictionaries
  selectedAccessType      String?         @map("selected_access_type")    // From AccessTypeDictionary.name
  selectedPaymentSource   String?         @map("selected_payment_source") // From PaymentSourceDictionary.sourceName


  subnet                  Subnet?         @relation(fields: [subnetId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  directVlan              VLAN?           @relation("DirectVLANIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([subnetId])
  @@index([directVlanId])
  @@index([status])
  @@index([allocatedTo])
  @@index([usageUnit])
  @@map("ip_addresses")
}


model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String?  // Username at the time of logging
  action    String   // e.g., 'create_subnet', 'user_login'
  details   String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull) // SetNull to keep logs if user deleted

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

// --- Dictionaries ---

model DeviceDictionary {
  id          String   @id @default(uuid())
  deviceName  String   @unique @map("device_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("device_dictionaries")
}

model PaymentSourceDictionary {
  id          String   @id @default(uuid())
  sourceName  String   @unique @map("source_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("payment_source_dictionaries")
}

model AccessTypeDictionary {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("access_type_dictionaries")
}

model InterfaceTypeDictionary {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., GigabitEthernet, ge-
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("interface_type_dictionaries")
}

