// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id         String    @id @default(cuid())
  username   String    @unique
  email      String    @unique
  password   String
  phone      String?
  avatar     String?
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id])
  lastLogin  DateTime? @map("last_login")
  auditLogs  AuditLog[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  group       String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?
  action    String
  timestamp DateTime @default(now())
  details   String?

  @@map("audit_logs")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String      @map("network_address")
  subnetMask     String      @map("subnet_mask")
  ipRange        String?     @map("ip_range")
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false) @map("dhcp_enabled")
  vlanId         String?     @map("vlan_id")
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("subnets")
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique @map("vlan_number")
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVLANIPAddresses")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("vlans")
}

model IPAddress {
  id                      String    @id @default(cuid())
  ipAddress               String    @map("ip_address")
  subnetId                String?   @map("subnet_id")
  subnet                  Subnet?   @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  directVlanId            String?   @map("direct_vlan_id")
  directVlan              VLAN?     @relation("DirectVLANIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull)
  status                  String
  isGateway               Boolean?  @default(false) @map("is_gateway")
  allocatedTo             String?   @map("allocated_to")
  usageUnit               String?   @map("usage_unit")
  contactPerson           String?   @map("contact_person")
  phone                   String?
  description             String?
  lastSeen                DateTime? @map("last_seen")

  peerUnitName            String?   @map("peer_unit_name")
  peerDeviceName          String?   @map("peer_device_name")
  peerPortName            String?   @map("peer_port_name")

  selectedAccessType      String?   @map("selected_access_type")
  selectedLocalDeviceName String?   @map("selected_local_device_name")
  selectedDevicePort      String?   @map("selected_device_port")
  selectedPaymentSource   String?   @map("selected_payment_source")

  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@unique([ipAddress, subnetId], name: "ipAddress_subnetId")
  @@map("ip_addresses")
}

model DeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique @map("device_name")
  port       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("device_dictionaries")
}

model PaymentSourceDictionary {
  id         String   @id @default(cuid())
  sourceName String   @unique @map("source_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("payment_source_dictionaries")
}

model AccessTypeDictionary {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("access_type_dictionaries")
}

model InterfaceTypeDictionary {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("interface_type_dictionaries")
}
