
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = [] // Add any preview features you are using, e.g., "fullTextSearch"
}

model Subnet {
  id             String      @id // Removed @default(cuid())
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation("VlanSubnets", fields: [vlanId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ipAddresses    IPAddress[] @relation("SubnetIPs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vlanId])
}

model VLAN {
  id          String   @id // Removed @default(cuid())
  vlanNumber  Int      @unique
  name        String?
  description String?
  subnets     Subnet[] @relation("VlanSubnets")
  ipAddresses IPAddress[] @relation("VlanDirectIPs") // IPs directly associated with this VLAN

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id             String        @id // Removed @default(cuid())
  ipAddress      String
  subnetId       String?
  subnet         Subnet?       @relation("SubnetIPs", fields: [subnetId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  directVlanId   String?       // For IPs directly associated with a VLAN, independent of subnet
  directVlan     VLAN?         @relation("VlanDirectIPs", fields: [directVlanId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status         String        // e.g., "allocated", "free", "reserved"
  isGateway      Boolean?      @default(false)
  allocatedTo    String?
  usageUnit      String?
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime?

  deviceConnectionsAsLocalIp DeviceConnection[] @relation("IpForLocalConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // Ensures IP is unique within its subnet or globally if subnetId is null
  @@index([subnetId])
  @@index([directVlanId])
  @@index([status])
}

model User {
  id          String     @id // Removed @default(cuid())
  username    String     @unique
  email       String     @unique
  password    String
  roleId      String
  role        Role       @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  avatar      String?
  lastLogin   DateTime?
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
}

model Role {
  id          String       @id // Removed @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String   @id // Removed @default(cuid())
  name        String   @unique // e.g., 'subnet.create'
  group       String   // e.g., 'Subnet Management'
  description String?
  roles       Role[]   @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String    @id // Removed @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade) // User might be deleted
  username  String?   // Denormalized username for easier display if user is deleted
  action    String
  timestamp DateTime  @default(now())
  details   String?

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

model Isp {
  id                        String             @id // Removed @default(cuid())
  name                      String             @unique
  description               String?
  contactInfo               String?
  providedDeviceConnections DeviceConnection[] @relation("IspForConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id                         String             @id // Removed @default(cuid())
  name                       String             @unique
  deviceType                 String?            // e.g., ROUTER, SWITCH, FIREWALL, SERVER, ACCESS_POINT, OTHER
  location                   String?
  managementIp               String?            @unique
  brand                      String?
  modelNumber                String?
  serialNumber               String?            @unique
  description                String?
  connectionsAsLocalDevice   DeviceConnection[] @relation("LocalDeviceForConnection")
  connectionsAsRemoteDevice  DeviceConnection[] @relation("RemoteDeviceForConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceConnection {
  id                 String   @id // Removed @default(cuid())
  localDeviceId      String
  localDevice        Device   @relation("LocalDeviceForConnection", fields: [localDeviceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  localIpId          String?
  localIpAddress     IPAddress? @relation("IpForLocalConnection", fields: [localIpId], references: [id], onDelete: SetNull, onUpdate: Cascade) // An IP on the local device used for this connection
  remoteDeviceId     String?
  remoteDevice       Device?  @relation("RemoteDeviceForConnection", fields: [remoteDeviceId], references: [id], onDelete: SetNull, onUpdate: Cascade) // Could be another managed device
  remoteHostnameOrIp String?  // Or an external IP/hostname
  ispId              String?
  isp                Isp?     @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  
  connectionType String     // E.g., ETHERNET_COPPER, ETHERNET_FIBER, WIFI, VPN_IPSEC, VPN_SSL, SERIAL, CELLULAR, SATELLITE, OTHER
  status           String     // E.g., ACTIVE, INACTIVE, MAINTENANCE, PLANNED, DECOMMISSIONED
  bandwidth          String?  // E.g., "1 Gbps", "100 Mbps"
  localInterface     String?  // E.g., "GigabitEthernet0/1", "eth0", "Port-channel1"
  remoteInterface    String?  // E.g., "Serial0/0/0", "Po1"
  description        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([localDeviceId])
  @@index([localIpId])
  @@index([remoteDeviceId])
  @@index([ispId])
  @@index([connectionType])
  @@index([status])
}
