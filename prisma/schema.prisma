// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  vlanId         String?
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[]
}

model VLAN {
  id          String      @id @default(cuid())
  vlanNumber  Int         @unique // 1-4094
  name        String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  subnets     Subnet[]
  ipAddresses IPAddress[]
}

model IPAddress {
  id           String   @id @default(cuid())
  ipAddress    String   // e.g., "192.168.1.100"
  subnetId     String?
  vlanId       String?  // IP-specific VLAN override
  status       String   // "allocated", "free", "reserved"
  allocatedTo  String?  // Device name, hostname, etc.
  description  String?
  lastSeen     DateTime? // For future use (e.g., ping sweep)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subnet       Subnet?  @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  vlan         VLAN?    @relation(fields: [vlanId], references: [id], onDelete: SetNull) // Direct VLAN assignment

  @@unique([ipAddress, subnetId]) // IP must be unique within a subnet
  @@index([status])
  @@index([allocatedTo])
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  email     String    @unique
  password  String    // Should be hashed in a real app
  roleId    String
  avatar    String?
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  role      Role      @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String   @id // e.g., "subnet.view", "subnet.create"
  name        String   @unique
  group       String   // e.g., "Subnet Management", "User Management"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("RolePermissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?   // Can be null if system action
  username  String?   // Denormalized for easier display, even if user is deleted
  action    String   // e.g., "create_subnet", "user_login"
  details   String?  // e.g., "Created subnet 192.168.1.0/24"
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) // For record creation tracking
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

