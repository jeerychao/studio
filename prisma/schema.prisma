
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model Permission {
  id          String @id
  name        String @unique
  group       String
  description String?
  roles       Role[] @relation("RolePermissions")

  @@map("permissions")
}

model Role {
  id            String       @id
  name          String       @unique
  description   String?
  users         User[]
  permissions   Permission[] @relation("RolePermissions")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("roles")
}

model User {
  id         String      @id
  username   String      @unique
  email      String      @unique
  password   String
  roleId     String
  role       Role        @relation(fields: [roleId], references: [id])
  avatar     String?
  lastLogin  DateTime?
  auditLogs  AuditLog[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("users")
}

model VLAN {
  id           String    @id
  vlanNumber   Int       @unique
  name         String?
  description  String?
  subnets      Subnet[]
  ipAddresses  IPAddress[] @relation("IPAddressDirectVLAN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("vlans")
}

model Subnet {
  id             String      @id
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("subnets")
}

model IPAddress {
  id             String    @id
  ipAddress      String
  status         String // "allocated", "free", "reserved"
  isGateway      Boolean?  @default(false)
  allocatedTo    String?
  usageUnit      String?
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime? @updatedAt // Can use @updatedAt if 'lastSeen' should always update on modification
  subnetId       String?
  subnet         Subnet?   @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId   String?
  directVlan     VLAN?     @relation("IPAddressDirectVLAN", fields: [directVlanId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt // This is the field causing P3018
  
  deviceConnections DeviceConnection[] @relation("LocalIpForConnection")

  @@unique([ipAddress, subnetId]) // Composite unique key
  @@map("ip_addresses")
}

model AuditLog {
  id        String   @id
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?
  action    String
  timestamp DateTime @default(now())
  details   String?

  @@map("audit_logs")
}

model Isp {
  id                String            @id
  name              String            @unique
  description       String?
  contactInfo       String?
  deviceConnections DeviceConnection[] @relation("IspForConnection")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("isps")
}

model Device {
  id                  String              @id
  name                String              @unique
  deviceType          String? // Maps to DeviceType enum in application
  location            String?
  managementIp        String?             @unique
  brand               String?
  modelNumber         String?
  serialNumber        String?             @unique
  description         String?
  localConnections    DeviceConnection[]  @relation("LocalDeviceForConnection")
  remoteConnections   DeviceConnection[]  @relation("RemoteDeviceForConnection")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map("devices")
}

model DeviceConnection {
  id                  String    @id
  localDeviceId       String
  localDevice         Device    @relation("LocalDeviceForConnection", fields: [localDeviceId], references: [id])
  localIpId           String?
  localIpAddress      IPAddress? @relation("LocalIpForConnection", fields: [localIpId], references: [id], onDelete: SetNull)
  remoteDeviceId      String?
  remoteDevice        Device?   @relation("RemoteDeviceForConnection", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  remoteHostnameOrIp  String?
  ispId               String?
  isp                 Isp?      @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull)
  connectionType      String    // Maps to DeviceConnectionType enum
  status              String    // Maps to DeviceConnectionStatus enum
  bandwidth           String?
  localInterface      String?
  remoteInterface     String?
  description         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("device_connections")
}
