
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../prisma/dev.db" 
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  phone     String?
  avatar    String?
  roleId    String    @map("role_id")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  role      Role      @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  group       String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model Subnet {
  id             String      @id @default(uuid())
  cidr           String      @unique // Canonical CIDR (e.g., 192.168.1.0/24)
  networkAddress String      @map("network_address")
  subnetMask     String      @map("subnet_mask")
  ipRange        String?     @map("ip_range")
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false) @map("dhcp_enabled")
  vlanId         String?     @map("vlan_id")
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("subnets")
}

model VLAN {
  id          String    @id @default(uuid())
  vlanNumber  Int       @unique @map("vlan_number")
  name        String?
  description String?
  subnets     Subnet[]
  directIPs   IPAddress[] @relation("VLANToDirectIPAddresses")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("vlans")
}

model IPAddress {
  id                      String          @id @default(uuid())
  ipAddress               String          @unique @map("ip_address")
  subnetId                String?         @map("subnet_id")
  directVlanId            String?         @map("direct_vlan_id")
  status                  String          // "allocated", "free", "reserved"
  isGateway               Boolean?        @default(false) @map("is_gateway")
  allocatedTo             String?         @map("allocated_to")
  usageUnit               String?         @map("usage_unit")
  contactPerson           String?         @map("contact_person")
  phone                   String?
  description             String?
  
  peerUnitName            String?         @map("peer_unit_name")
  peerDeviceName          String?         @map("peer_device_name")
  peerPortName            String?         @map("peer_port_name")

  selectedAccessType      String?         @map("selected_access_type")
  selectedLocalDeviceName String?         @map("selected_local_device_name")
  selectedDevicePort      String?         @map("selected_device_port")
  selectedPaymentSource   String?         @map("selected_payment_source")
  
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at") // Changed from lastSeen

  subnet                  Subnet?         @relation(fields: [subnetId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  directVlan              VLAN?           @relation("VLANToDirectIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull, onUpdate: Cascade)


  @@index([status])
  @@index([allocatedTo])
  @@index([usageUnit])
  @@map("ip_addresses")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String?
  action    String
  timestamp DateTime @default(now())
  details   String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull) // onDelete: SetNull: if user is deleted, log remains but userId is nullified.

  @@map("audit_logs")
}

model DeviceDictionary {
  id         String   @id @default(uuid())
  deviceName String   @unique @map("device_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("device_dictionaries")
}

model PaymentSourceDictionary {
  id         String   @id @default(uuid())
  sourceName String   @unique @map("source_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("payment_source_dictionaries")
}

model AccessTypeDictionary {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("access_type_dictionaries")
}

model InterfaceTypeDictionary {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "GigabitEthernet", "ge-", "Eth0/0"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("interface_type_dictionaries")
}

// Removed DeviceConnection and ISP models as they are deprecated/integrated elsewhere.

```
