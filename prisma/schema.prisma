// prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String      @id @default(uuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false)
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Restrict) // Restrict deletion if VLAN is in use
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model VLAN {
  id           String      @id @default(uuid())
  vlanNumber   Int         @unique // 1-4094
  name         String?
  description  String?
  subnets      Subnet[]
  ipAddresses  IPAddress[] @relation("DirectVLANForIP") // IPs directly assigned to this VLAN
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model IPAddress {
  id            String        @id @default(uuid())
  ipAddress     String        // e.g., "192.168.1.100"
  subnetId      String?
  subnet        Subnet?       @relation(fields: [subnetId], references: [id], onDelete: SetNull) // If subnet deleted, IP becomes unassigned from subnet
  directVlanId  String?       // For IPs directly assigned to a VLAN, not via subnet
  directVlan    VLAN?         @relation("DirectVLANForIP", fields: [directVlanId], references: [id], onDelete: SetNull)
  status        String        // "allocated", "free", "reserved"
  isGateway     Boolean?      @default(false)
  allocatedTo   String?       // e.g., "Server-01", "User-PC"
  usageUnit     String?       // e.g., "Marketing Department", "R&D Lab"
  contactPerson String?
  phone         String?
  description   String?
  lastSeen      DateTime?     @updatedAt // Automatically updates on any change, can represent last active or modification time
  createdAt     DateTime      @default(now())

  @@unique([ipAddress, subnetId], name: "unique_ip_in_subnet")
  @@index([status])
  @@index([allocatedTo])
}

model User {
  id          String    @id @default(uuid())
  username    String    @unique
  email       String    @unique
  password    String // Store hashed passwords in a real app
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  avatar      String?
  lastLogin   DateTime?
  auditLogs   AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id // e.g., "subnet.create", "user.delete"
  name        String   @unique // e.g., "Create Subnets"
  group       String   // e.g., "Subnet Management"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // Can be null for system actions
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull) // If user deleted, log remains but without userId
  username  String?  // Denormalized for easier display even if user is deleted
  action    String   // e.g., "create_subnet", "user_login"
  details   String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

// ISP Model (Phase 2)
model Isp { // Changed from ISP to Isp for Prisma convention
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  contactInfo  String?
  // deviceConnections DeviceConnection[] // Future relation for Phase 3
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Device Model (Phase 2)
// Removed DeviceType enum definition from here as SQLite doesn't support it natively.
// We'll use a String type in the model and manage enum consistency at the application level.

model Device {
  id           String  @id @default(uuid())
  name         String  @unique
  deviceType   String? // Was DeviceType?, now String?. Validation via App enum.
  location     String?
  managementIp String? @unique // Assuming management IP should be unique
  brand        String?
  modelNumber  String?
  serialNumber String? @unique // Assuming serial number should be unique
  description  String?
  // localDeviceConnections DeviceConnection[] @relation("LocalDeviceConnections") // Future relation
  // remoteDeviceConnections DeviceConnection[] @relation("RemoteDeviceConnections") // Future relation
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// DeviceConnection Model (Phase 3 Placeholder)
// This model will link devices, IPs, and ISPs.
// It's added as a placeholder to establish basic relations
// and avoid complex migrations later if these relations are added
// to already existing and populated tables.
model DeviceConnection {
  id                String     @id @default(uuid())
  connectionType    String?    // e.g., "WAN", "VPN", "Direct"
  localIpId         String?    // IP on the local device for this connection
  localIpAddress    IPAddress? @relation(fields: [localIpId], references: [id], onDelete: SetNull)
  localDeviceId     String     // ID of the local device
  localDevice       Device     @relation(fields: [localDeviceId], references: [id], onDelete: Cascade) // If local device is deleted, connection is removed
  remoteIp          String?    // IP Address of the remote end (if applicable, could be external)
  // remoteDeviceId String? // ID of the remote device (if it's another managed device)
  // remoteDevice   Device?   @relation("RemoteDeviceConnections", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  ispId             String?    // ISP providing this connection
  isp               Isp?       @relation(fields: [ispId], references: [id], onDelete: SetNull)
  bandwidth         String?    // e.g., "100 Mbps"
  status            String?    // e.g., "Active", "Backup", "Down"
  description       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([localDeviceId])
  // @@index([remoteDeviceId])
  @@index([ispId])
}
