
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String     @id @default(uuid())
  cidr           String     @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String? // New field for Subnet name
  description    String?
  dhcpEnabled    Boolean?   @default(false) // New field for DHCP status
  vlanId         String?
  vlan           VLAN?      @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]
  // deviceConnections DeviceConnection[] @relation("SubnetConnections") // Example if subnet can be directly connected
}

model VLAN {
  id            String      @id @default(uuid())
  vlanNumber    Int         @unique
  name          String?
  description   String?
  subnets       Subnet[]
  ipAddresses   IPAddress[] @relation("IPDirectlyOnVLAN")
}

model IPAddress {
  id             String    @id @default(uuid())
  ipAddress      String
  subnetId       String?
  subnet         Subnet?   @relation(fields: [subnetId], references: [id], onDelete: Cascade) // Cascade delete if subnet is gone
  directVlanId   String?
  directVlan     VLAN?     @relation("IPDirectlyOnVLAN", fields: [directVlanId], references: [id], onDelete: SetNull)
  status         String // "allocated", "free", "reserved"
  isGateway      Boolean?  @default(false)
  allocatedTo    String?
  usageUnit      String?
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime? @updatedAt

  deviceConnection DeviceConnection?

  @@unique([ipAddress, subnetId], name: "unique_ip_address_in_subnet_or_global")
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  email     String     @unique
  password  String
  avatar    String?
  lastLogin DateTime?
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String @id // e.g., "subnet.create", "user.view"
  name        String @unique
  group       String // e.g., "Subnet Management", "User Access"
  description String?
  roles       Role[] @relation("RolePermissions")
}

model AuditLog {
  id        String    @id @default(uuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull) // SetNull if user is deleted
  username  String // Store username denormalized for history even if user is deleted
  action    String
  timestamp DateTime  @default(now())
  details   String?
}

// Phase 2: New Models
model Isp { // Changed from ISP to Isp (PascalCase for better Prisma convention)
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  contactInfo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deviceConnections DeviceConnection[]
}

enum DeviceType {
  ROUTER
  SWITCH
  FIREWALL
  SERVER
  ACCESS_POINT
  OLT
  DDN_DEVICE
  OTHER
}

model Device {
  id           String     @id @default(uuid())
  name         String     @unique
  deviceType   DeviceType?
  location     String?
  managementIp String?    @unique
  brand        String?
  modelNumber  String?
  serialNumber String?    @unique // Serial numbers should generally be unique
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  deviceConnectionsLocal  DeviceConnection[] @relation("LocalDeviceConnections")
  // deviceConnectionsRemote DeviceConnection[] @relation("RemoteDeviceConnections") // If tracking remote end of connection
}

// Phase 3: Connection Model (placeholder, will be detailed later)
model DeviceConnection {
  id String @id @default(uuid())
  // --- Relations to be added in Phase 3 ---
  // Example fields (will be refined)
  ipAddress   IPAddress? @relation(fields: [ipAddressId], references: [id])
  ipAddressId String?

  localDevice   Device @relation("LocalDeviceConnections", fields: [localDeviceId], references: [id])
  localDeviceId String

  // remoteDevice   Device? @relation("RemoteDeviceConnections", fields: [remoteDeviceId], references: [id])
  // remoteDeviceId String?

  isp   Isp? @relation(fields: [ispId], references: [id])
  ispId String?

  // --- Attributes of the connection ---
  localPort        String? // e.g., "GigabitEthernet0/1"
  // remotePort       String?
  connectionType   String? // e.g., "Copper", "Fiber", "Wireless"
  bandwidth        String? // e.g., "1Gbps"
  status           String? // e.g., "Up", "Down", "Maintenance"
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
