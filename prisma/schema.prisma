datasource db {
  provider = "sqlite"
  url      = "file:/home/user/studio/prisma/ipam.db"
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique // e.g., 10, 20
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] // IPs that might be directly assigned to this VLAN, not via a subnet

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id           String  @id @default(cuid())
  ipAddress    String  // e.g., "192.168.1.100"
  status       String  // "allocated", "free", "reserved"
  allocatedTo  String? // Device or service name
  description  String?
  subnetId     String?
  subnet       Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  vlanId       String? // Direct VLAN assignment for this IP (overrides subnet's VLAN if set)
  vlan         VLAN?   @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  lastSeen     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensure IP is unique within a subnet, OR globally if not in a subnet
  @@unique([ipAddress, subnetId])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String // Hashed password
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  avatar    String?
  lastLogin DateTime?

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // "Administrator", "Operator", "Viewer"
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String @id // e.g., "subnet.create", "user.view"
  name        String @unique // e.g., "Create Subnets"
  group       String // e.g., "Subnet Management"
  description String?
  roles       Role[] @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String? // Denormalized username for logs where user might be deleted
  action    String   // e.g., "create_subnet", "login_user"
  details   String?  // e.g., "Subnet 192.168.1.0/24 created"
  timestamp DateTime @default(now())
}
