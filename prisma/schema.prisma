
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., 192.168.1.0/24
  networkAddress String      // e.g., 192.168.1.0
  subnetMask     String      // e.g., 255.255.255.0
  ipRange        String?     // e.g., 192.168.1.1 - 192.168.1.254
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ipAddresses    IPAddress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id            String    @id @default(cuid())
  vlanNumber    Int       @unique // 1-4094
  name          String?   // New field for VLAN Name
  description   String?
  subnets       Subnet[]
  ipAddresses   IPAddress[] @relation("IPAddressToVLAN") // Explicit relation name for IP-specific VLAN

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id           String  @id @default(cuid())
  ipAddress    String  // e.g., 192.168.1.100
  subnetId     String?
  subnet       Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull, onUpdate: Cascade) // onDelete: SetNull if IP can exist without subnet
  vlanId       String? // For IP-specific VLAN assignment, overriding subnet's VLAN
  vlan         VLAN?   @relation("IPAddressToVLAN", fields: [vlanId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status       String  // e.g., "allocated", "free", "reserved"
  allocatedTo  String? // e.g., "John's PC", "Server-01"
  description  String?
  lastSeen     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // An IP must be unique within its subnet, or globally if no subnet
  // If an IP can be globally unique regardless of subnet, then @@unique([ipAddress])
}

model User {
  id          String     @id @default(cuid())
  username    String     @unique
  email       String     @unique
  password    String // In a real app, this would be a hash
  avatar      String?
  roleId      String
  role        Role       @relation(fields: [roleId], references: [id])
  lastLogin   DateTime?
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id // e.g., "subnet.create"
  name        String  @unique // e.g., "Create Subnets"
  group       String  // e.g., "Subnet Management"
  description String?
  roles       Role[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // Can be null for system actions
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?  // Denormalized username for easier display, even if user is deleted
  action    String   // e.g., "create_subnet", "user_login"
  details   String?  // e.g., "Created subnet 192.168.1.0/24"
  timestamp DateTime @default(now())
}
