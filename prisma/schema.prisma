
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., "192.168.1.0/24"
  networkAddress String      // e.g., "192.168.1.0"
  subnetMask     String      // e.g., "255.255.255.0"
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Cascade) // Cascade delete if VLAN is deleted
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model VLAN {
  id          String      @id @default(cuid())
  vlanNumber  Int         @unique // 1-4094
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] // IPs directly assigned to this VLAN, not via subnet
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model IPAddress {
  id           String    @id @default(cuid())
  ipAddress    String    // e.g., "192.168.1.100"
  status       String    // "allocated", "free", "reserved"
  allocatedTo  String?   // Device name, user, etc.
  description  String?
  lastSeen     DateTime? // For potential future use (e.g., ping checks)
  subnetId     String?
  subnet       Subnet?   @relation(fields: [subnetId], references: [id], onDelete: SetNull) // SetNull if subnet is deleted
  vlanId       String?   // Direct VLAN assignment (overrides subnet's VLAN if set)
  vlan         VLAN?     @relation(fields: [vlanId], references: [id], onDelete: SetNull) // SetNull if VLAN is deleted
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Ensure unique IP within a subnet, or unique globally if no subnet
  @@unique([ipAddress, subnetId])
}

model User {
  id          String     @id @default(cuid())
  username    String     @unique
  email       String     @unique
  password    String     // Store hashed password in a real app
  avatar      String?    // URL or path to avatar image
  roleId      String
  role        Role       @relation(fields: [roleId], references: [id])
  auditLogs   AuditLog[]
  lastLogin   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id // e.g., "subnet.create", "user.delete"
  name        String   @unique // e.g., "Create Subnets"
  group       String   // e.g., "Subnet Management"
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // Can be null for system actions
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?  // Denormalized username for easier display if user is deleted
  action    String   // e.g., "create_subnet", "login_failed"
  details   String?  // Additional details, can be JSON string
  timestamp DateTime @default(now())
  ipAddress String?  // IP of the user performing the action
}

model SystemSetting {
  key       String   @id // e.g., "auditLogRetentionPeriod"
  value     String   // e.g., "90" (days) or "forever"
  updatedAt DateTime @updatedAt
}

