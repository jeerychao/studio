
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model Permission {
  id          String @id
  name        String @unique
  group       String
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String       @id
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id        String     @id
  username  String     @unique
  email     String     @unique
  password  String
  avatar    String?
  lastLogin DateTime?
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VLAN {
  id                String        @id
  vlanNumber        Int           @unique
  name              String?
  description       String?
  subnets           Subnet[]
  directIpAddresses IPAddress[]   @relation("IpToDirectVlan")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Subnet {
  id             String      @id
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[] @relation("IpToSubnet")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model IPAddress {
  id             String   @id
  ipAddress      String
  subnetId       String?
  subnet         Subnet?  @relation("IpToSubnet", fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId   String?
  directVlan     VLAN?    @relation("IpToDirectVlan", fields: [directVlanId], references: [id], onDelete: SetNull) // Relation for direct VLAN assignment
  status         String   // "allocated", "free", "reserved"
  isGateway      Boolean? @default(false)
  allocatedTo    String?
  usageUnit      String?
  contactPerson  String?
  phone          String?
  description    String?
  lastSeen       DateTime? @updatedAt // Can also be manually set if needed
  deviceConnections DeviceConnection[] @relation("IpToDeviceConnection")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // IP must be unique within its subnet, or globally if no subnet
}

model AuditLog {
  id        String    @id
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?   // Denormalized for cases where user might be deleted
  action    String
  details   String?
  timestamp DateTime  @default(now())
  // No updatedAt for audit logs as they are immutable once created
}

model Isp {
  id                String    @id
  name              String    @unique
  description       String?
  contactInfo       String?
  deviceConnections DeviceConnection[] @relation("IspForConnection")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Device {
  id                String    @id
  name              String    @unique
  deviceType        String?   // e.g., ROUTER, SWITCH, FIREWALL, SERVER
  location          String?
  managementIp      String?   @unique
  brand             String?
  modelNumber       String?
  serialNumber      String?   @unique
  description       String?
  localConnections  DeviceConnection[] @relation("LocalDeviceConnections")
  remoteConnections DeviceConnection[] @relation("RemoteDeviceConnections")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model DeviceConnection {
  id                  String   @id
  localDeviceId       String
  localDevice         Device   @relation("LocalDeviceConnections", fields: [localDeviceId], references: [id])
  localIpId           String?
  localIpAddress      IPAddress? @relation("IpToDeviceConnection", fields: [localIpId], references: [id], onDelete: SetNull)
  remoteDeviceId      String?
  remoteDevice        Device?  @relation("RemoteDeviceConnections", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  remoteHostnameOrIp  String?
  ispId               String?
  isp                 Isp?     @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull)
  connectionType      String   // e.g., ETHERNET_COPPER, ETHERNET_FIBER, WIFI, VPN
  status              String   // e.g., ACTIVE, INACTIVE, MAINTENANCE
  bandwidth           String?
  localInterface      String?
  remoteInterface     String?
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
