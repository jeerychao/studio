
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../prisma/dev.db" // Ensure this path is correct for your setup
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  password    String
  phone       String?
  avatar      String?
  roleId      String    @map("role_id")
  role        Role      @relation(fields: [roleId], references: [id])
  auditLogs   AuditLog[]
  lastLogin   DateTime? @map("last_login")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., Administrator, Operator, Viewer
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid()) // Using PERMISSIONS enum values as IDs
  name        String   @unique
  group       String // e.g., Subnet Management, User Management
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., 192.168.1.0/24
  networkAddress String      @map("network_address")
  subnetMask     String      @map("subnet_mask")
  ipRange        String?     @map("ip_range")
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false) @map("dhcp_enabled")
  vlanId         String?     @map("vlan_id")
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("subnets")
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique @map("vlan_number") // 1-4094
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVlanIPAddresses") // IPs directly assigned to this VLAN
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("vlans")
}

model IPAddress {
  id                      String    @id @default(cuid())
  ipAddress               String    @map("ip_address")
  subnetId                String?   @map("subnet_id")
  subnet                  Subnet?   @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  directVlanId            String?   @map("direct_vlan_id")
  directVlan              VLAN?     @relation("DirectVlanIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull)
  status                  String    // "allocated", "free", "reserved"
  isGateway               Boolean?  @default(false) @map("is_gateway")
  allocatedTo             String?   @map("allocated_to")
  usageUnit               String?   @map("usage_unit")
  contactPerson           String?   @map("contact_person")
  phone                   String?
  description             String?
  lastSeen                DateTime? @map("last_seen")

  // New generalized peer fields
  peerUnitName            String?   @map("peer_unit_name")
  peerDeviceName          String?   @map("peer_device_name") // Name of the device from DeviceDictionary
  peerPortName            String?   @map("peer_port_name")   // Port from DeviceDictionary for peerDeviceName

  // Local connection details
  selectedLocalDeviceName String?   @map("selected_local_device_name") // Name of the device from DeviceDictionary
  selectedDevicePort      String?   @map("selected_device_port")       // Port from DeviceDictionary for selectedLocalDeviceName
  selectedAccessType      String?   @map("selected_access_type")       // Name from AccessTypeDictionary
  selectedPaymentSource   String?   @map("selected_payment_source")    // Name from PaymentSourceDictionary

  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@unique([ipAddress, subnetId], name: "ipAddress_subnetId")
  @@index([status])
  @@index([allocatedTo])
  @@map("ip_addresses")
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull) // SetNull to keep log if user deleted
  username  String?   // Denormalized for easier display if user is deleted
  action    String
  timestamp DateTime  @default(now())
  details   String?

  @@map("audit_logs")
}

// Renamed from LocalDeviceDictionary
model DeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique @map("device_name")
  port       String?  // Port identifier, possibly constructed with InterfaceTypeDictionary
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("device_dictionaries")
}

model PaymentSourceDictionary {
  id         String   @id @default(cuid())
  sourceName String   @unique @map("source_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("payment_source_dictionaries")
}

model AccessTypeDictionary {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("access_type_dictionaries")
}

// Renamed from NetworkInterfaceTypeDictionary
model InterfaceTypeDictionary {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "GigabitEthernet", "ge-", "Port-channel"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("interface_type_dictionaries")
}
