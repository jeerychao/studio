datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // Docker build will use ENV, runtime will use ENV
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
}

// Removed enum IPAddressStatus as SQLite does not support it.
// Application logic will handle string validation for 'allocated', 'free', 'reserved'.

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  description    String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] // IPs that might be directly assigned a VLAN without a subnet, or override subnet's VLAN
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model IPAddress {
  id           String   @id @default(cuid())
  ipAddress    String
  subnetId     String?
  subnet       Subnet?  @relation(fields: [subnetId], references: [id])
  vlanId       String?  // Optional: IP-specific VLAN override or assignment if not in a subnet
  vlan         VLAN?    @relation(fields: [vlanId], references: [id])
  status       String   // Changed from IPAddressStatus enum to String. Expected: "allocated", "free", "reserved"
  allocatedTo  String?
  description  String?
  lastSeen     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // An IP must be unique within a given subnet, or globally if no subnet.
                                  // Consider if IP should be globally unique regardless of subnet.
                                  // If IP must be globally unique, then just @@unique([ipAddress])
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  email     String     @unique
  password  String // Store hashed passwords in a real app
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  avatar    String?
  lastLogin DateTime?
  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., Administrator, Operator, Viewer
  description String?
  users       User[]
  permissions Permission[] @relation("RoleToPermission")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id // e.g., 'subnet.create', 'user.view'
  name        String   @unique // e.g., Create Subnets
  group       String   // e.g., Subnet Management
  description String?
  roles       Role[]   @relation("RoleToPermission")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // Can be null for system actions
  user      User?    @relation(fields: [userId], references: [id])
  username  String?  // Denormalized for easier display if user is deleted
  action    String   // e.g., 'create_subnet', 'user_login'
  details   String?
  timestamp DateTime @default(now())
}
