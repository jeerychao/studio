
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model Permission {
  id          String   @id @default(cuid()) // Assuming permissions might be added via UI later
  name        String   @unique
  group       String
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String   @id // Roles are fixed and seeded with specific IDs
  name        String   @unique
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String     @id // Users are seeded with specific IDs for mock purposes
  username  String     @unique
  email     String     @unique
  password  String
  avatar    String?
  lastLogin DateTime?
  roleId    String
  role      Role       @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VLAN {
  id                String      @id // VLANs are seeded with specific IDs
  vlanNumber        Int         @unique
  name              String?
  description       String?
  subnets           Subnet[]
  directIpAddresses IPAddress[] @relation("IpToDirectVlan")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Subnet {
  id             String     @id // Subnets are seeded with specific IDs
  cidr           String     @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?   @default(false)
  description    String?
  vlanId         String?
  vlan           VLAN?      @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[] @relation("IpToSubnet")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model IPAddress {
  id                String    @id // IPAddresses are seeded with specific IDs
  ipAddress         String
  subnetId          String?
  subnet            Subnet?   @relation("IpToSubnet", fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId      String?
  directVlan        VLAN?     @relation("IpToDirectVlan", fields: [directVlanId], references: [id], onDelete: SetNull)
  status            String    // "allocated", "free", "reserved"
  isGateway         Boolean?  @default(false)
  allocatedTo       String?
  usageUnit         String?
  contactPerson     String?
  phone             String?
  description       String?
  lastSeen          DateTime? // Manual update, no @updatedAt
  deviceConnections DeviceConnection[] @relation("IpToDeviceConnection")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([ipAddress, subnetId])
}

model AuditLog {
  id        String   @id @default(cuid()) // AuditLogs should auto-generate IDs
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?
  action    String
  details   String?
  timestamp DateTime @default(now())
}

model Isp {
  id                String             @id @default(cuid()) // ISPs created via UI need auto-ID
  name              String             @unique
  description       String?
  contactInfo     String?
  deviceConnections DeviceConnection[] @relation("IspForConnection")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Device {
  id                String             @id @default(cuid()) // Devices created via UI need auto-ID
  name              String             @unique
  deviceType        String?
  location          String?
  managementIp      String?            @unique
  brand             String?
  modelNumber       String?
  serialNumber      String?            @unique
  description       String?
  localConnections  DeviceConnection[] @relation("LocalDeviceConnections")
  remoteConnections DeviceConnection[] @relation("RemoteDeviceConnections")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model DeviceConnection {
  id                 String    @id @default(cuid()) // Connections created via UI need auto-ID
  localDeviceId      String
  localDevice        Device    @relation("LocalDeviceConnections", fields: [localDeviceId], references: [id])
  localIpId          String?
  localIpAddress     IPAddress? @relation("IpToDeviceConnection", fields: [localIpId], references: [id], onDelete: SetNull)
  remoteDeviceId     String?
  remoteDevice       Device?   @relation("RemoteDeviceConnections", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  remoteHostnameOrIp String?
  ispId              String?
  isp                Isp?      @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull)
  connectionType     String
  status             String
  bandwidth          String?
  localInterface     String?
  remoteInterface    String?
  description        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
