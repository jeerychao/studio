datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String     @id @default(cuid())
  username    String     @unique
  email       String     @unique
  password    String
  phone       String?
  roleId      String
  avatar      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lastLogin   DateTime?
  role        Role       @relation(fields: [roleId], references: [id])
  auditLogs   AuditLog[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  group       String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false)
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: Restrict)
  ipAddresses    IPAddress[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model VLAN {
  id          String    @id @default(cuid())
  vlanNumber  Int       @unique
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVLANIPs")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model IPAddress {
  id                      String    @id @default(cuid())
  ipAddress               String
  subnetId                String?
  directVlanId            String?
  status                  String // "allocated", "free", "reserved"
  isGateway               Boolean?  @default(false)
  allocatedTo             String?
  usageUnit               String?
  contactPerson           String?
  phone                   String?
  description             String?
  lastSeen                DateTime? @default(now())
  subnet                  Subnet?   @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  directVlan              VLAN?     @relation("DirectVLANIPs", fields: [directVlanId], references: [id], onDelete: SetNull)

  // Removed operator specific fields
  // selectedOperatorName    String?
  // selectedOperatorDevice  String?

  // New generic peer fields
  peerUnitName            String?    // Manual input for peer/customer/partner name
  peerDeviceName          String?    // Name of the device on the peer side (from LocalDeviceDictionary)
  peerPortName            String?    // Port on the peer device (derived from selected LocalDeviceDictionary entry's port)

  selectedAccessType      String?
  selectedLocalDeviceName String?
  selectedDevicePort      String?
  selectedPaymentSource   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // IP must be unique within its subnet, or globally if subnetId is null
  @@index([subnetId])
  @@index([directVlanId])
  @@index([status])
  @@index([allocatedTo])
  @@index([usageUnit])
  @@index([peerUnitName])
  @@index([peerDeviceName])
  @@index([selectedLocalDeviceName])
}

// OperatorDictionary is removed

model LocalDeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique // e.g., "CoreSwitch-A", "Firewall-Main"
  port       String?  // e.g., "GigabitEthernet1/0/1", "eth0" - can be constructed using NetworkInterfaceTypeDictionary
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PaymentSourceDictionary {
  id         String   @id @default(cuid())
  sourceName String   @unique // e.g., "Self-funded", "GovProject-A"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AccessTypeDictionary {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Dedicated Fiber", "Broadband PPPoE", "Wireless PtP"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NetworkInterfaceTypeDictionary {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "GigabitEthernet", "TenGigabitEthernet", "ge-", "xe-"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String?  // Denormalized for easier display, even if user is deleted
  action    String
  details   String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}
