datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  description    String?
  ipAddresses    IPAddress[] @relation("SubnetToIPAddresses")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id          String      @id @default(cuid())
  vlanNumber  Int         @unique
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("VLANToDirectIPAddresses")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id            String    @id @default(cuid())
  ipAddress     String
  subnetId      String?
  subnet        Subnet?   @relation("SubnetToIPAddresses", fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId  String?
  directVlan    VLAN?     @relation("VLANToDirectIPAddresses", fields: [directVlanId], references: [id], onDelete: SetNull)
  status        String // "allocated", "free", "reserved"
  isGateway     Boolean?  @default(false)
  allocatedTo   String?
  usageUnit     String?
  contactPerson String?
  phone         String?
  description   String?
  lastSeen      DateTime? @updatedAt

  // Explicitly named relation to DeviceConnection where this IP is local
  deviceConnectionsAsLocalIp DeviceConnection[] @relation("IpForLocalConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId])
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  email     String    @unique
  password  String
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id])
  avatar    String?
  lastLogin DateTime?

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RoleToPermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  group       String
  description String?
  roles       Role[]  @relation("RoleToPermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  action    String
  details   String?
  timestamp DateTime @default(now())
}

model Isp {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  contactInfo String?

  // Explicitly named relation to DeviceConnection
  providedDeviceConnections DeviceConnection[] @relation("IspForConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id           String  @id @default(cuid())
  name         String  @unique
  deviceType   String? // Managed as String in DB, validated by app (src/types DeviceType enum)
  location     String?
  managementIp String? @unique
  brand        String?
  modelNumber  String?
  serialNumber String? @unique
  description  String?

  // Explicitly named relations to DeviceConnection
  connectionsAsLocalDevice  DeviceConnection[] @relation("LocalDeviceForConnection")
  connectionsAsRemoteDevice DeviceConnection[] @relation("RemoteDeviceForConnection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceConnection {
  id             String  @id @default(cuid())
  description    String?
  connectionType String // e.g., "Ethernet", "Fiber", "VPN", "Wireless", "Serial"
  status         String // e.g., "Active", "Inactive", "Maintenance", "Planned"
  bandwidth      String? // e.g., "1 Gbps", "100 Mbps"

  localDeviceId  String
  localDevice    Device  @relation("LocalDeviceForConnection", fields: [localDeviceId], references: [id], onDelete: Cascade)
  localInterface String? // e.g., "GigabitEthernet0/1", "eth0"

  localIpId      String?
  localIpAddress IPAddress? @relation("IpForLocalConnection", fields: [localIpId], references: [id], onDelete: SetNull)

  remoteDeviceId     String? // Optional: if remote end is another managed device
  remoteDevice       Device? @relation("RemoteDeviceForConnection", fields: [remoteDeviceId], references: [id], onDelete: SetNull)
  remoteHostnameOrIp String? // If remote end is unmanaged or external IP
  remoteInterface    String? // e.g., "Port-Channel1", "eth1" (remote side's perspective)

  ispId String?
  isp   Isp?    @relation("IspForConnection", fields: [ispId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
