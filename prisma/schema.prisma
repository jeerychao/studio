
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String      @map("network_address")
  subnetMask     String      @map("subnet_mask")
  ipRange        String?     @map("ip_range")
  name           String?
  description    String?
  dhcpEnabled    Boolean?    @default(false) @map("dhcp_enabled")
  vlanId         String?     @map("vlan_id")
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  ipAddresses    IPAddress[] @relation("SubnetToIPAddress")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model VLAN {
  id          String      @id @default(cuid())
  vlanNumber  Int         @unique @map("vlan_number")
  name        String?
  description String?
  subnets     Subnet[]
  directIPs   IPAddress[] @relation("VLANToDirectIPAddresses")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model IPAddress {
  id            String  @id @default(cuid())
  ipAddress     String  @map("ip_address")
  subnetId      String? @map("subnet_id")
  subnet        Subnet? @relation("SubnetToIPAddress", fields: [subnetId], references: [id])
  directVlanId  String? @map("direct_vlan_id")
  directVlan    VLAN?   @relation("VLANToDirectIPAddresses", fields: [directVlanId], references: [id])

  status        String
  isGateway     Boolean? @default(false) @map("is_gateway")
  allocatedTo   String?  @map("allocated_to")
  usageUnit     String?  @map("usage_unit")
  contactPerson String?  @map("contact_person")
  phone         String?
  description   String?
  lastSeen      DateTime? @updatedAt @map("last_seen")

  peerUnitName            String? @map("peer_unit_name")
  peerDeviceName          String? @map("peer_device_name")
  peerPortName            String? @map("peer_port_name")
  selectedAccessType      String? @map("selected_access_type")
  selectedLocalDeviceName String? @map("selected_local_device_name")
  selectedDevicePort      String? @map("selected_device_port")
  selectedPaymentSource   String? @map("selected_payment_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ipAddress, subnetId])
  @@index([allocatedTo])
  @@index([usageUnit])
  @@index([status])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  lastLogin DateTime? @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditLogs AuditLog[] @relation("UserToAuditLog")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RoleToPermission")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Permission {
  id          String @id @default(cuid())
  name        String @unique
  group       String
  description String?
  roles       Role[] @relation("RoleToPermission")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation("UserToAuditLog", fields: [userId], references: [id])
  username  String?  // Store username denormalized for cases where user might be deleted
  action    String
  details   String?
  timestamp DateTime @default(now())

  // No separate createdAt/updatedAt, timestamp is the primary time field
}

// Dictionaries
model DeviceDictionary {
  id         String   @id @default(cuid())
  deviceName String   @unique @map("device_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
}

model PaymentSourceDictionary {
  id         String   @id @default(cuid())
  sourceName String   @unique @map("source_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
}

model AccessTypeDictionary {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model InterfaceTypeDictionary {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}
