
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  password    String
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  avatar      String?
  lastLogin   DateTime?
  auditLogs   AuditLog[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  group       String
  description String?
  roles       Role[]  @relation("RolePermissions")
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id], onDelete:Restrict)
  description    String?
  ipAddresses    IPAddress[]
}

model VLAN {
  id           String      @id @default(cuid())
  vlanNumber   Int         @unique
  name         String?
  description  String?
  subnets      Subnet[]
  ipAddresses  IPAddress[] // IPs directly assigned to this VLAN, not via a subnet
}

model IPAddress {
  id            String    @id @default(cuid())
  ipAddress     String
  subnetId      String?
  subnet        Subnet?   @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  vlanId        String?   // For IP-specific VLAN override, independent of subnet's VLAN
  vlan          VLAN?     @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  status        String    // e.g., "allocated", "free", "reserved"
  allocatedTo   String?
  description   String?
  lastSeen      DateTime?

  @@unique([ipAddress, subnetId]) // Ensures IP is unique within a subnet, or globally if subnetId is null
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String?  // To store username at the time of logging, in case user is deleted
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  timestamp DateTime @default(now()) // This field effectively serves as createdAt
  // Removed createdAt and updatedAt as they were redundant with timestamp and Prisma's default behavior
}
