
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  email      String   @unique
  password   String // Encrypted password
  phone      String? // Encrypted phone number, optional
  // passwordIv String? // Removed
  // phoneIv    String? // Removed
  avatar     String?
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  lastLogin  DateTime?
  auditLogs  AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., 'subnet.create'
  group       String   // e.g., 'Subnet Management'
  description String?
  roles       Role[]   @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subnet {
  id             String      @id @default(cuid())
  cidr           String      @unique // e.g., 192.168.1.0/24
  networkAddress String      // e.g., 192.168.1.0
  subnetMask     String      // e.g., 255.255.255.0
  ipRange        String?     // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?
  dhcpEnabled    Boolean?    @default(false)
  vlanId         String?
  vlan           VLAN?       @relation(fields: [vlanId], references: [id])
  description    String?
  ipAddresses    IPAddress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VLAN {
  id          String   @id @default(cuid())
  vlanNumber  Int      @unique // e.g., 10, 20
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("DirectVlanIPAddresses") // IPs directly associated with this VLAN

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IPAddress {
  id          String  @id @default(cuid())
  ipAddress   String  // e.g., 192.168.1.100
  subnetId    String?
  subnet      Subnet? @relation(fields: [subnetId], references: [id], onDelete: Cascade) // IPs deleted if subnet is deleted
  directVlanId String? // For IPs directly assigned to a VLAN, not through a subnet
  directVlan  VLAN?   @relation("DirectVlanIPAddresses", fields: [directVlanId], references: [id])

  status      String // e.g., "allocated", "free", "reserved"
  isGateway   Boolean? @default(false)
  allocatedTo String?
  usageUnit   String?
  contactPerson String?
  phone       String? // Encrypted
  description String?
  lastSeen    DateTime? @default(now())

  // Fields for selected dictionary values
  selectedOperatorName    String?
  selectedOperatorDevice  String?
  selectedAccessType      String?
  selectedLocalDeviceName String?
  selectedDevicePort      String?
  selectedPaymentSource   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipAddress, subnetId]) // IP must be unique within its subnet, or globally if no subnet
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull) // Set user to null if deleted
  username  String?  // Denormalized for cases where user might be deleted
  action    String   // e.g., "create_subnet", "user_login"
  timestamp DateTime @default(now())
  details   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Dictionary Models
model OperatorDictionary {
  id                String    @id @default(cuid())
  operatorName      String    @unique // e.g., 中国电信
  operatorDevice    String?   // e.g., OLT-ZX-C300
  accessType        String?   // e.g., 独享, 共享
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LocalDeviceDictionary {
  id          String    @id @default(cuid())
  deviceName  String    @unique // e.g., 核心交换机-A栋
  port        String?   // e.g., Ten-GigabitEthernet1/0/1
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PaymentSourceDictionary {
  id          String    @id @default(cuid())
  sourceName  String    @unique // e.g., 自费, 财政付费-项目A
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
