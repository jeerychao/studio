
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  avatar    String?
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id])
  lastLogin DateTime?
  auditLogs AuditLog[] // Relation to AuditLog model

  @@index([roleId])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Administrator", "Operator", "Viewer"
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id          String   @id // Use predefined PermissionId strings
  name        String   @unique
  group       String   // e.g., "Subnet Management", "User Management"
  description String?
  roles       Role[]   @relation("RolePermissions")
}

model Subnet {
  id             String     @id @default(uuid())
  cidr           String     @unique
  networkAddress String
  subnetMask     String
  ipRange        String?
  name           String?    // New: For "子网名称"
  description    String?
  dhcpEnabled    Boolean?   @default(false) // New: For "dhp启用"
  vlanId         String?
  vlan           VLAN?      @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]

  @@index([vlanId])
}

model VLAN {
  id          String   @id @default(uuid())
  vlanNumber  Int      @unique
  name        String?
  description String?
  subnets     Subnet[]
  ipAddresses IPAddress[] @relation("IPDirectlyOnVLAN")
}

model IPAddress {
  id             String    @id @default(uuid())
  ipAddress      String
  subnetId       String?
  subnet         Subnet?   @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId   String?   // If this IP is directly on a VLAN, not through a subnet
  directVlan     VLAN?     @relation("IPDirectlyOnVLAN", fields: [directVlanId], references: [id], onDelete: SetNull)
  status         String    // "allocated", "free", "reserved"
  isGateway      Boolean?  @default(false) // New: For "是否网关"
  allocatedTo    String?   // General allocation target (e.g., device, service)
  usageUnit      String?   // New: For "使用单位"
  contactPerson  String?   // New: For "联系人"
  phone          String?   // New: For "电话"
  description    String?
  lastSeen       DateTime? @updatedAt // Automatically updated on record change

  // Store vlanId separately for direct IP-to-VLAN assignment (independent of subnet's VLAN)
  // This field was named 'vlanId' in previous versions, renaming to 'directVlanId' for clarity.
  // The relation "IPDirectlyOnVLAN" clarifies this is not the subnet's VLAN.
  // If an IP is in a subnet, its effective VLAN is typically the subnet's VLAN.
  // This `directVlanId` is for overrides or IPs not in any subnet.

  @@unique([subnetId, ipAddress], name: "unique_ip_in_subnet_or_global_if_subnetId_null")
  @@index([subnetId])
  @@index([directVlanId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // User who performed the action (can be null for system actions)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?  // Store username denormalized for cases where user might be deleted
  action    String   // e.g., "create_subnet", "login_user"
  details   String?  // More details about the action
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}
