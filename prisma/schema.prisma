
// prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // 确保这里指向您实际的数据库文件，通常在 prisma/dev.db
}

generator client {
  provider = "prisma-client-js"
}

model Subnet {
  id             String    @id @default(uuid())
  cidr           String    @unique // e.g., "192.168.1.0/24"
  networkAddress String    // e.g., "192.168.1.0"
  subnetMask     String    // e.g., "255.255.255.0"
  ipRange        String?   // e.g., "192.168.1.1 - 192.168.1.254"
  name           String?
  description    String?
  dhcpEnabled    Boolean?  @default(false)
  vlanId         String?
  vlan           VLAN?     @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  ipAddresses    IPAddress[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model VLAN {
  id              String    @id @default(uuid())
  vlanNumber      Int       @unique // 1-4094
  name            String?
  description     String?
  subnets         Subnet[]
  ipAddresses     IPAddress[] // IPs directly assigned to this VLAN (not via subnet)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model IPAddress {
  id                String     @id @default(uuid())
  ipAddress         String     // e.g., "192.168.1.100"
  status            String     // "allocated", "free", "reserved"
  isGateway         Boolean?   @default(false)
  allocatedTo       String?    // e.g., "Server-01", "John Doe's PC"
  usageUnit         String?    // e.g., "R&D Department", "Finance Team"
  contactPerson     String?    // e.g., "Jane Doe"
  phone             String?    // e.g., "13800138000"
  description       String?
  subnetId          String?
  subnet            Subnet?    @relation(fields: [subnetId], references: [id], onDelete: SetNull)
  directVlanId      String?    // For IPs directly assigned to a VLAN, overriding subnet's VLAN
  directVlan        VLAN?      @relation(fields: [directVlanId], references: [id], onDelete: SetNull)
  lastSeen          DateTime?  @updatedAt // Or a specific last_seen timestamp updated by a cron/tool
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Back-relation to DeviceConnection for localIpAddress
  deviceConnections DeviceConnection[] @relation("LocalIpDeviceConnections")
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String    // In a real app, this would be a hash
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id])
  avatar    String?
  lastLogin DateTime?
  auditLogs AuditLog[] // User who performed the action
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // "Administrator", "Operator", "Viewer"
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id // e.g., "subnet.create", "user.delete"
  name        String   @unique // e.g., "Create Subnets"
  group       String   // e.g., "Subnet Management"
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  // User who performed the action (optional, for system actions)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String   // Store username denormalized for easier display even if user is deleted
  action    String   // e.g., "create_subnet", "user_login"
  details   String?  // e.g., "Created subnet 192.168.1.0/24"
  timestamp DateTime @default(now())
}

// Model for ISPs
model Isp { // Renamed from ISP to Isp
  id                String    @id @default(uuid())
  name              String    @unique
  description       String?
  contactInfo       String?   // e.g., "Support: 10000, sales@isp.com"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Back-relation to DeviceConnection for isp
  deviceConnections DeviceConnection[] @relation("IspDeviceConnections")
}

// Model for Devices
model Device {
  id                  String    @id @default(uuid())
  name                String    @unique // e.g., "Core-Switch-A1", "Firewall-Main"
  deviceType          String?   // Stored as String for SQLite compatibility. App-level enum validation.
                                // Valid values defined in src/types/index.ts: DeviceType enum
  location            String?   // e.g., "Data Center A, Rack 5, U22"
  managementIp        String?   @unique // Optional management IP
  brand               String?
  modelNumber         String?
  serialNumber        String?   @unique
  description         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Back-relation to DeviceConnection for localDevice
  localDeviceConnections DeviceConnection[] @relation("LocalDeviceConnections")
  // remoteDeviceConnections DeviceConnection[] @relation("RemoteDeviceConnections") // Placeholder for future if a Device can also be a remote end
}

// Model for Device Connections
model DeviceConnection {
  id                String     @id @default(uuid())
  connectionType    String?    // e.g., "WAN", "LAN", "VPN", "Fiber"

  localIpId         String?    // IP on the local device for this connection
  localIpAddress    IPAddress? @relation("LocalIpDeviceConnections", fields: [localIpId], references: [id], onDelete: SetNull)

  localDeviceId     String     // ID of the local device
  localDevice       Device     @relation("LocalDeviceConnections", fields: [localDeviceId], references: [id], onDelete: Cascade) // If local device is deleted, connection is removed

  remoteIp          String?    // IP Address of the remote end (if applicable, could be external)
  // remoteDeviceId String? // Placeholder for connection to another managed device
  // remoteDevice   Device?   @relation("RemoteDeviceConnections", fields: [remoteDeviceId], references: [id], onDelete: SetNull) // Placeholder for future

  ispId             String?    // ISP providing this connection
  isp               Isp?       @relation("IspDeviceConnections", fields: [ispId], references: [id], onDelete: SetNull)

  bandwidth         String?    // e.g., "100 Mbps"
  description       String?
  status            String?    // e.g., "Active", "Inactive", "Maintenance"
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // @@index([localDeviceId]) // If frequently querying connections by local device
  // @@index([ispId])         // If frequently querying connections by ISP
}
